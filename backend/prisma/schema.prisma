generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  clerkId      String        @unique
  role         String        @default("CUSTOMER")
  createdAt    DateTime      @default(now())
  customOrders CustomOrder[]
  orders       Order[]
}

model Product {
  id          String         @id @default(uuid())
  name        String
  slug        String         @unique
  description String?
  basePrice   Int
  stock       Int            @default(0)
  category    String?
  material    String?
  finish      String?
  metadata    Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  images      ProductImage[]

  @@index([category])
  @@index([material])
  @@index([finish])
  @@index([createdAt])
}

model ProductImage {
  id        String  @id @default(uuid())
  productId String
  imageUrl  String
  altText   String?
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model CustomOrder {
  id              String   @id @default(uuid())
  userId          String
  customerEmail   String?
  description     String
  referenceImages String[]
  dimensions      String?
  material        String?
  status          String
  quotedPrice     Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([createdAt])
}

model Order {
  id            String   @id @default(uuid())
  userId        String
  customerEmail String?
  type          String
  items         Json?
  totalAmount   Int
  paymentStatus String
  paymentMethod String?
  safepayTrackerToken String?
  paidAt        DateTime?
  status        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([safepayTrackerToken])
  @@index([createdAt])
}

model Inquiry {
  id        String   @id @default(uuid())
  fullName  String
  email     String
  phone     String
  city      String
  message   String
  status    String   @default("NEW")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
}
